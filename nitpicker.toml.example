[defaults]
debate = true
max_turns = 200
log_trajectories = true
compact_threshold = 120000

[aggregator]
model = "claude-sonnet-4-6"
provider = "anthropic"
# api_key_env = "ANTHROPIC_API_KEY"  # default; override if needed

# OpenRouter with automatic free-model selection (omit model field)
[[reviewer]]
name = "openrouter-free-a"
provider = "openrouter"

[[reviewer]]
name = "openrouter-free-b"
provider = "openrouter"

# [[reviewer]]
# name = "anthropic"
# model = "claude-sonnet-4-6"
# provider = "anthropic"

# Gemini via Antigravity keyring (research only — reuses the agy CLI token).
# Requires building with `--features antigravity` (off by default).
# [[reviewer]]
# name = "gemini"
# model = "gemini-3.1-pro-low"
# provider = "gemini"
# auth = "agy-keyring"

# [[reviewer]]
# name = "openai"
# model = "gpt-5.5"
# provider = "openai"

# ChatGPT/Codex subscription (research only — reuses the Codex CLI token from
# ~/.codex/auth.json; no API key needed). Run `codex login` first.
# [[reviewer]]
# name = "codex"
# model = "gpt-5.5"
# provider = "openai"
# auth = "codex"

# OpenRouter with explicit model
# [[reviewer]]
# name = "openrouter"
# model = "minimax/minimax-m2.7"
# provider = "openrouter"
