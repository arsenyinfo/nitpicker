[defaults]
debate = true
max_turns = 100
# log_trajectories = true
# compact_threshold = 120000

[aggregator]
model = "claude-sonnet-4-6"
provider = "anthropic"
# api_key_env = "ANTHROPIC_API_KEY"  # default; override if needed

# OpenRouter with automatic free-model selection (omit model field)
[[reviewer]]
name = "openrouter-auto"
provider = "openrouter"

[[reviewer]]
name = "openrouter-auto-2"
provider = "openrouter"

